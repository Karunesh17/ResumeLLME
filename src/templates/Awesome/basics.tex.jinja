%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%     Profile
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\begin{center}
	\headerfirstnamestyle{\VAR{firstName}} \headerlastnamestyle{\VAR{lastName}}\\
	\vspace{2mm}
    \BLOCK{ if email } {\faEnvelope\ \href{mailto:\VAR{email}}{\VAR{email}}} | \BLOCK{ endif }
    \BLOCK{ if phone } {\faMobile\ \href{tel:\VAR{phone|replace(' ', '')|replace('-', '')|replace('(', '')|replace(')', '')}}{\VAR{phone}}} | \BLOCK{ endif }
    \BLOCK{ if address } {\faMapMarker\ \VAR{address}} | \BLOCK{ endif }
    \BLOCK{ if website } {\faLink\ \href{\BLOCK{ if website.startswith('http') }\VAR{website}\BLOCK{ else }https://\VAR{website}\BLOCK{ endif }}{\VAR{website}}} \BLOCK{ endif }\
\end{center}